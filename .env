# System Configuration
ENVIRONMENT=development
LOG_LEVEL=info

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/valorant_coach
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=valorant_coach
USE_SQLITE=true

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Security and Authentication
JWT_SECRET=ai-valorant-coach-super-secret-jwt-key-production-ready-2025!!
ADMIN_EMAIL=preetsinghal087@gmail.com
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Third Party APIs
# Set RIOT_API_KEY to a real key from developer.riotgames.com to use official Riot API
# Note: Riot RSO OAuth is NOT publicly available - it requires official Riot partnership
RIOT_API_KEY=mock_riot_api_key_12345
TRACKER_GG_API_KEY=mock_tracker_api_key_67890

# Player Portal Provider
# true  = MockProvider (no API calls, instant data, works for any Riot ID you type)
# false = HenrikDevProvider (real data — requires HENRIK_API_KEY below)
USE_MOCK_PROVIDER=false

# HenrikDev API Key — get a FREE key at: https://app.henrikdev.xyz
# Required when USE_MOCK_PROVIDER=false
# Leave empty to keep using Mock provider
HENRIK_API_KEY=HDEV-e957bcb7-38ee-4771-a3cc-34069db3505d

GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
