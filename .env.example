# System Configuration
ENVIRONMENT=development
LOG_LEVEL=info

# Database Configuration
# For production/docker, use the host name of the db service (db)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/valorant_coach
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=valorant_coach

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Security and Authentication
JWT_SECRET=supersecretjwtsecretkeyshouldbechangeinproduction12345!
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Third Party APIs
RIOT_API_KEY=mock_riot_api_key_12345
TRACKER_GG_API_KEY=mock_tracker_api_key_67890

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
